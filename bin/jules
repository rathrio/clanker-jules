#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'fileutils'
require 'optparse'

require File.expand_path('../lib/jules', File.dirname(File.realpath(__FILE__)))

# --- Configuration ---
options = {
  provider: ENV.fetch('JULES_PROVIDER', 'openrouter').downcase,
  model: ENV.fetch('JULES_MODEL', nil),
  list_models: false
}

provider_set_by_cli = false
model_set_by_cli = false

OptionParser.new do |opts|
  opts.banner = "Usage: #{File.basename($PROGRAM_NAME)} [options]"

  opts.on('-p', '--provider PROVIDER', "Provider: #{Jules::Provider.all_names.join(', ')}") do |provider|
    options[:provider] = provider.downcase
    provider_set_by_cli = true
  end

  opts.on('-m', '--model MODEL', 'Model name for the selected provider') do |model|
    options[:model] = model
    model_set_by_cli = true
  end

  opts.on('-l', '--list-models', 'List models for the selected provider and exit') do
    options[:list_models] = true
  end

  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit
  end
end.parse!

# If the provider is explicitly changed on the CLI but no explicit model is set,
# fall back to that provider's default model instead of reusing JULES_MODEL.
options[:model] = nil if provider_set_by_cli && !model_set_by_cli

begin
  PROVIDER = Jules::Provider.build(options[:provider], model: options[:model])
rescue KeyError
  warn "Unknown provider '#{options[:provider]}'. Use #{Jules::Provider.all_names.join(', ')}."
  exit 1
end

# Ensure directories exist
FileUtils.mkdir_p(File.expand_path('~/.agents/skills'))
CHATS_DIR = File.expand_path('~/.jules/chats')
FileUtils.mkdir_p(CHATS_DIR)

if options[:list_models]
  begin
    models = PROVIDER.list_models
    if models.is_a?(Hash) && models[:error]
      Jules::Terminal.print_error(models[:error])
      exit 1
    end

    models.each do |entry|
      next unless entry.is_a?(Hash)

      model_name = entry['id'] || entry['name']
      next unless model_name

      puts(model_name)
    end

    exit
  rescue NotImplementedError => e
    Jules::Terminal.print_error(e.message)
    exit 1
  end
end

skills = Jules::Skill.all
tools = Jules::Tool.declarations(format: PROVIDER.tool_format)

Jules::Terminal.print_opening_scene(
  PROVIDER.provider_label, PROVIDER.model,
  tool_count: tools.size,
  skill_names: skills.keys
)

# --- Main Application ---
messages = []
session_started_at = nil

system_prompt_path = File.expand_path('~/.jules/SYSTEM.md')
system_prompt = if File.exist?(system_prompt_path)
                  File.read(system_prompt_path)
                else
                  'You are Jules, a straight and to-the-point general-purpose terminal assistant.'
                end
system_prompt += "\n\nAdditional instructions from AGENTS.md:\n#{File.read('AGENTS.md')}" if File.exist?('AGENTS.md')

unless skills.empty?
  skill_definitions = skills.each_value.map do |skill|
    "<skill><name>#{skill.name}</name><description>#{skill.description}</description></skill>"
  end
  system_prompt += "\n\nThe following skills are available:\n#{skill_definitions.join("\n")}"
end

flush_chat_log = lambda do
  next unless session_started_at && !messages.empty?

  log_file = File.join(CHATS_DIR, "#{session_started_at}.json")
  File.write(log_file, Jules::Message.format_history(messages, format: :gemini).to_json)
end

at_exit do
  flush_chat_log.call
rescue StandardError => e
  warn "Failed to save chat log: #{e.message}"
end

loop do
  input = Jules::Terminal.read_input
  next if input.empty?

  case Jules::Terminal.parse_slash_command(input)
  when :clear
    messages.clear
    session_started_at = nil
    Jules::Terminal.print_scene_cut
    next
  when :multi
    input = Jules::Terminal.read_multiline
    next if input.empty?
  end

  session_started_at ||= Time.now.strftime('%Y-%m-%dT%H%M%S%Z')
  messages << Jules::Message.new('user', [{ text: input }])

  loop do
    response = Jules::Terminal.with_spinner(leading_newline: true) do
      PROVIDER.generate_content(messages, tools, system_prompt: system_prompt)
    end

    parsed_response = PROVIDER.parse_response(response)

    extra_parts = parsed_response[:extra_parts] || []

    case parsed_response[:type]
    when :message
      messages << Jules::Message.new('model', extra_parts + [{ text: parsed_response[:data] }])
      Jules::Terminal.print_assistant(parsed_response[:data])
      break
    when :tool_calls
      model_parts = extra_parts + parsed_response[:data].map do |call|
        { function_call: { name: call[:name], args: call[:args], id: call[:id] } }
      end
      messages << Jules::Message.new('model', model_parts)

      tool_results = parsed_response[:data].map do |call|
        tool_class = Jules::Tool.find(call[:name])
        Jules::Terminal.print_tool_execution(tool_class.render_execution(call[:args]))
        result = Jules::Tool.call(call[:name], call[:args])
        Jules::Terminal.print_tool_preview(call[:name], result)
        { function_response: { name: call[:name], result: result, id: call[:id] } }
      end
      messages << Jules::Message.new('tool', tool_results)
    when :error
      Jules::Terminal.print_error(parsed_response[:data], raw: response.inspect)
      break
    end
  end
rescue Interrupt
  Jules::Terminal.print_interrupt
end
