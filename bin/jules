#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'fileutils'
require 'optparse'

require File.expand_path('../lib/jules', File.dirname(File.realpath(__FILE__)))

options = {
  provider: ENV.fetch('JULES_PROVIDER', 'openrouter').downcase,
  model: ENV.fetch('JULES_MODEL', nil),
  list_models: false
}

provider_set_by_cli = false
model_set_by_cli = false

OptionParser.new do |opts|
  opts.banner = "Usage: #{File.basename($PROGRAM_NAME)} [options]"

  opts.on('-p', '--provider PROVIDER', "Provider: #{Jules::Provider.all_names.join(', ')}") do |provider|
    options[:provider] = provider.downcase
    provider_set_by_cli = true
  end

  opts.on('-m', '--model MODEL', 'Model name for the selected provider') do |model|
    options[:model] = model
    model_set_by_cli = true
  end

  opts.on('-s', '--system-prompt PROMPT', 'Override the system prompt') do |prompt|
    options[:system_prompt] = prompt
  end

  opts.on('-b', '--bare', 'Disable all tools and skills') do
    options[:bare] = true
  end

  opts.on('--stakeout', 'Stakeout mode: read-only — no shell, no edits, no writes') do
    options[:stakeout] = true
  end

  opts.on('-l', '--list-models', 'List models for the selected provider and exit') do
    options[:list_models] = true
  end

  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit
  end
end.parse!

options[:model] = nil if provider_set_by_cli && !model_set_by_cli

unless Jules::Provider.all_names.include?(options[:provider])
  warn "Unknown provider '#{options[:provider]}'. Use #{Jules::Provider.all_names.join(', ')}."
  exit 1
end

begin
  provider = Jules::Provider.build(options[:provider], model: options[:model])
rescue KeyError => e
  warn "Provider '#{options[:provider]}' configuration error: #{e.message}"
  exit 1
end

FileUtils.mkdir_p(File.expand_path('~/.agents/skills'))
chats_dir = File.expand_path('~/.jules/chats')
FileUtils.mkdir_p(chats_dir)

if options[:list_models]
  begin
    models_result = provider.list_models
    if models_result.err?
      Jules::Terminal.print_error(models_result.message)
      exit 1
    end

    models_result.value.each do |entry|
      next unless entry.is_a?(Hash)

      model_name = entry['id'] || entry['name']
      next unless model_name

      puts(model_name)
    end

    exit
  rescue NotImplementedError => e
    Jules::Terminal.print_error(e.message)
    exit 1
  end
end

bare = options[:bare]
stakeout = options[:stakeout] ? true : false
skills = bare ? {} : Jules::Skill.all
lobotomized = bare || provider.lobotomized?

tool_names = if lobotomized && stakeout
               Jules::Tool::LOBOTOMIZED_TOOLS & Jules::Tool::STAKEOUT_TOOLS
             elsif lobotomized
               Jules::Tool::LOBOTOMIZED_TOOLS
             elsif stakeout
               Jules::Tool::STAKEOUT_TOOLS
             end
tools = bare ? [] : Jules::Tool.declarations(format: provider.tool_format, only: tool_names)
allowed_tools = stakeout ? Jules::Tool::STAKEOUT_TOOLS : nil

Jules::Terminal.start_screenplay_buffer
Jules::Terminal.print_opening_scene(
  provider.provider_label, provider.model,
  tool_count: tools.size,
  skill_names: skills.keys,
  lobotomized: lobotomized,
  stakeout: stakeout
)

system_prompt = if options[:system_prompt]
                  options[:system_prompt]
                elsif File.exist?(system_prompt_path = File.expand_path('~/.jules/SYSTEM.md'))
                  File.read(system_prompt_path)
                else
                  'You are Jules, a neonoir detective working the terminal beat — a straight, ' \
                    'to-the-point coding and technical assistant with a little grit in the voice. ' \
                    'Keep answers direct, accurate, and useful. Hardboiled phrasing is fine in small ' \
                    'doses; clarity wins every time. Skip the purple prose and unprompted theatrics.'
                end
system_prompt += "\n\nAdditional instructions from AGENTS.md:\n#{File.read('AGENTS.md')}" if !lobotomized && File.exist?('AGENTS.md')

unless skills.empty?
  skill_definitions = skills.each_value.map do |skill|
    "<skill><name>#{skill.name}</name><description>#{skill.description}</description></skill>"
  end
  system_prompt += "\n\nThe following skills are available:\n#{skill_definitions.join("\n")}"
end

if stakeout
  system_prompt += "\n\nYou are on stakeout: observe and report only. Do not modify files, " \
                   'run shell commands, or change system state under any circumstances. ' \
                   'The write, edit, and bash tools are off the table — even if asked.'
end

Jules::Chat.new(
  provider: provider,
  tools: tools,
  system_prompt: system_prompt,
  chats_dir: chats_dir,
  allowed_tools: allowed_tools
).run
